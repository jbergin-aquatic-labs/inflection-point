{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdleShutdown": {
    "PollIntervalSeconds": 10,
    "GracePeriodSeconds": 30,
    "InitialConnectionTimeoutSeconds": 300
  },
  "SessionReaper": {
    "ReaperIntervalSeconds": 30,
    "SessionTimeoutSeconds": 90
  }
}
