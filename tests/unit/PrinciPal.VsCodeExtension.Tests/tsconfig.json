{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./out",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "vscode": ["./node_modules/@types/vscode"]
    }
  },
  "include": [
    "**/*.ts",
    "../../src/PrinciPal.VsCodeExtension/src/**/*.ts",
    "../../src/PrinciPal.VsCodeExtension/__mocks__/**/*.ts"
  ],
  "exclude": ["node_modules", "out"]
}
